# ======================================================================
# WaffleBear 환경 변수 템플릿
# ----------------------------------------------------------------------
# 사용법:  cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# 그 뒤 아래 <...> placeholder 값을 실제 값으로 채운 다음
#   docker compose up -d --build
# 로 전체 스택을 기동한다.
#
# 주의: .env 는 .gitignore 에 등록되어 있다(절대 커밋 금지). 이 .example 만 커밋한다.
# 인프라 호스트(redis/db/minio) 기본값은 docker-compose 네트워크 기준으로 맞춰져 있다.
# ======================================================================

# ---------- 보안 / 인증 ----------
export JWT_KEY=<base64-32바이트-이상-임의-키>
export JWT_EXPIRE=3600000

# ---------- 데이터베이스 (docker: db 서비스) ----------
export DB_SERVER=db
export DB_URL=jdbc:mariadb://db:3306/web
export DB_ID=root
export DB_PASS=<DB-root-비밀번호>

# ---------- Redis (docker: redis 서비스) ----------
export REDIS_HOST=redis
export REDIS_PORT=6379

# ---------- 애플리케이션 URL ----------
export APP_FRONTEND_URL=http://localhost
export APP_BACKEND_URL=http://localhost:8080
export APP_SECURE_COOKIE=false

# ---------- 관리자 초기 계정 ----------
export ADMIN_EMAIL=admin@example.com
export ADMIN_NAME=admin
export ADMIN_ROLE=ROLE_ADMIN
export ADMIN_PASSWORD=<관리자-비밀번호>

# ---------- 메일(SMTP) ----------
export MAIL_PORT=587
export MAIL_ID=<smtp-계정>
export MAIL_PASS=<smtp-앱-비밀번호>

# ---------- OAuth2 ----------
export GOOGLE_CLIENT_ID=<google-client-id>
export GOOGLE_CLIENT_SECRET=<google-client-secret>
export NAVER_CLIENT_ID=<naver-client-id>
export NAVER_CLIENT_SECRET=<naver-client-secret>
export CLIENT_ID=<oauth-client-id>
export CLIENT_SECRET=<oauth-client-secret>

# ---------- 결제 (Portone) ----------
export PORTONE_SECRET=<portone-secret>

# ---------- 스토리지 공급자 ----------
# minio | s3
export STORAGE_PROVIDER=minio

# ---------- MinIO (docker: minio 서비스, 버킷은 앱이 부팅 시 자동 생성) ----------
export MINIO_API=http://minio:9000
export MINIO_NAME=<minio-root-user>
export MINIO_SECRET=<minio-root-password>
export MINIO_CLOUD_BUCKET=waffle-cloud
export MINIO_WORKSPACE_BUCKET=waffle-workspace
export MINIO_REGION=us-east-1

# ---------- AWS S3 (STORAGE_PROVIDER=s3 일 때만 필요) ----------
export S3AMAZON_API=
export S3AMAZON_NAME=
export S3AMAZON_SECRET=
export S3AMAZON_CLOUD_BUCKET=
export S3AMAZON_WORKSPACE_BUCKET=
export S3AMAZON_REGION=ap-northeast-2

# ---------- docker compose 이미지 태그(선택) ----------
export COMPOSE_IMAGE_TAG=latest
